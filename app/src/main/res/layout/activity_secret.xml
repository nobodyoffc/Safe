<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include layout="@layout/common_toolbar" />

    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/secret_list_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp" />

            <!-- Statistics Bar -->
            <include
                android:id="@+id/statistics_bar"
                layout="@layout/statistics_bar" />

        </LinearLayout>

    </ScrollView>


    <include
        android:id="@+id/sort_control"
        layout="@layout/secret_sort_control" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/delete_button"
            style="@style/ButtonStyle"
            android:layout_margin="8dp"
            android:text="@string/delete" />

        <Button
            android:id="@+id/export_button"
            style="@style/ButtonStyle"
            android:layout_margin="8dp"
            android:text="@string/export_tx" />
        <Button
            android:id="@+id/import_button"
            style="@style/ButtonStyle"
            android:layout_margin="8dp"
            android:text="@string/import_tx" />

        <Button
            android:id="@+id/create_button"
            style="@style/ButtonStyle"
            android:layout_margin="8dp"
            android:text="@string/create" />

    </LinearLayout>

</LinearLayout> 